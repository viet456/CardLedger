# ─── Docker Postgres ───────────────────────────────────────────────────
POSTGRES_USER=my_user
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=cardledger

# Connection string for the Next.js app (same DB, different hostnames depending on context)
# For Docker: use postgres as host
# For local dev: use localhost
DATABASE_URL=postgres://cardledger:change_me_to_a_secure_password@localhost:5432/cardledger

R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_ACCOUNT_ID=your-account-id

# ─── R2 Database Backups ──────────────────────────────────────────────
# Can be the same bucket as above or a separate one
R2_BACKUP_BUCKET=your-backup-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
BACKUP_RETENTION_DAYS=30
NEXT_PUBLIC_R2_PUBLIC_URL=your-bucket-url
NEXT_PUBLIC_APP_URL=your-site-url
REVALIDATION_TOKEN=invalidates-cache

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

RESEND_API_KEY= #email api key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=